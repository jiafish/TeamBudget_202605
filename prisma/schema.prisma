generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                Int      @id @default(autoincrement())
  loginNumber       String   @unique
  passwordHash      String
  role              String   @default("MEMBER")
  name              String
  monthlyAllocation Int      @default(0)
  balance           Int      @default(0)
  createdAt         DateTime @default(now())

  expenses              ExpenseRecord[]
  monthlyAllocationLogs MonthlyAllocationLog[]
  reimbursementTargets  ReimbursementDecision[] @relation("ReimbursementTarget")
  reimbursementAsManager ReimbursementDecision[] @relation("ReimbursementManager")
  allocationSettingsAsMember MemberAllocationSettingLog[] @relation("AllocationSettingMember")
  allocationSettingsAsManager MemberAllocationSettingLog[] @relation("AllocationSettingManager")
}

model MemberAllocationSettingLog {
  id                           Int      @id @default(autoincrement())
  memberUserId                 Int
  managerUserId                Int
  monthlyAllocationAfter       Int
  requestedBackfillFromMonth   String?
  requestedBackfillToMonth     String?
  effectiveBackfillFromMonth   String?
  effectiveBackfillToMonth     String?
  backfilledMonthsCount        Int      @default(0)
  createdAt                    DateTime @default(now())

  member  User @relation("AllocationSettingMember", fields: [memberUserId], references: [id])
  manager User @relation("AllocationSettingManager", fields: [managerUserId], references: [id])

  @@index([memberUserId, createdAt])
}

model ReimbursementDecision {
  id            Int      @id @default(autoincrement())
  targetUserId  Int
  managerUserId Int
  reimbursed    Boolean
  creditAmount  Int
  note          String?
  createdAt     DateTime @default(now())

  target  User @relation("ReimbursementTarget", fields: [targetUserId], references: [id])
  manager User @relation("ReimbursementManager", fields: [managerUserId], references: [id])
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  expenses ExpenseRecord[]
}

model ExpenseRecord {
  id          Int      @id @default(autoincrement())
  userId      Int
  amount      Int
  date        DateTime
  description String
  receiptPath String?
  categoryId  Int?
  createdAt   DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])
}

model MonthlyAllocationLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  amount    Int
  month     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, month])
}
